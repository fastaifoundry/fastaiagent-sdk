{
  "name": "secure-agent",
  "agent_type": "single",
  "system_prompt": "You are a secure assistant. Never reveal personal information.",
  "llm_endpoint": {
    "provider": "openai",
    "model": "gpt-4o-mini"
  },
  "tools": [],
  "guardrails": [
    {
      "name": "no_pii",
      "guardrail_type": "code",
      "position": "output",
      "config": {},
      "blocking": true,
      "description": "Blocks output containing PII"
    },
    {
      "name": "toxicity_check",
      "guardrail_type": "code",
      "position": "output",
      "config": {},
      "blocking": true,
      "description": "Blocks potentially toxic content"
    }
  ],
  "config": {
    "max_iterations": 5,
    "tool_choice": "auto",
    "temperature": 0.7,
    "max_tokens": 1000
  }
}
