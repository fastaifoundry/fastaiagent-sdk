# LangGraph compatibility test workspace (off-tree probes, not part of the SDK)
.langgraph-compat/

# CrewAI compatibility test workspace (off-tree probes, not part of the SDK)
.crewai-compat/

# security_review_1.md L5 — never commit a real ``.env`` from any
# example directory. The committed template is always ``.env.example``;
# anyone copying it to ``.env`` to fill in real keys must keep their
# copy local. This belt-and-braces pattern protects new examples that
# forget to ship their own per-dir ``.gitignore``.
.env
**/.env
!**/.env.example

# MkDocs build output
site/

# Frontend build artifacts (built fresh by CI; bundled into the wheel)
ui-frontend/node_modules/
ui-frontend/dist/
ui-frontend/test-results/
ui-frontend/playwright-report/
fastaiagent/ui/static/*
!fastaiagent/ui/static/.gitkeep

# Internal / private
claude_files/
.claude/

# Scripts / recordings / videos
scripts/

# Ad-hoc source dirs created by examples that seed a KB (e.g. 37, 41).
.fastaiagent-source-docs/

# Per-run artifacts from the regression-from-trace template
# (trace IDs, intermediate outputs). Re-created each run.
examples/regression-from-trace/.fastaiagent-demo/

# Article companion folders — prose + screenshots + per-run artifacts are
# published externally (LinkedIn, blog, PDF), not tracked in the repo.
examples/articles/

# OS
.DS_Store
Thumbs.db
