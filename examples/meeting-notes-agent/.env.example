# OpenAI is the default LLM provider. Required.
OPENAI_API_KEY=sk-...

# Optional model override. Defaults to gpt-4o.
# LLM_MODEL=gpt-4o-mini

# Email backend selector for the per-attendee followup-email step.
# "mock" appends to .fastaiagent/outbox.jsonl; flip to "sendgrid" once
# you've filled in tools.py and the SendGrid credentials below.
EMAIL_BACKEND=mock
# SENDGRID_API_KEY=...
# SENDGRID_FROM=meeting-bot@yourcompany.com

# Optional FastAIAgent Platform connection.
# FASTAIAGENT_API_KEY=fa_k_...
# FASTAIAGENT_PROJECT=meeting-notes-agent
