# OpenAI is the default LLM provider. Required.
OPENAI_API_KEY=sk-...

# Optional model override. Defaults to gpt-4o.
# LLM_MODEL=gpt-4o-mini

# Backend selectors. "mock" runs offline; flip to "clearbit" / "salesforce" /
# "sendgrid" once you've filled in the corresponding _real_* function in tools.py.
ENRICHMENT_BACKEND=mock
CRM_BACKEND=mock
EMAIL_BACKEND=mock

# Real-provider keys — uncomment when switching off mock.
# CLEARBIT_API_KEY=...
# SALESFORCE_API_KEY=...
# SENDGRID_API_KEY=...

# Score threshold for "qualified" — affects the chain's conditional edge.
# 0.0–1.0; default 0.7.
QUALIFIED_THRESHOLD=0.7

# Optional FastAIAgent Platform connection.
# FASTAIAGENT_API_KEY=fa_k_...
# FASTAIAGENT_PROJECT=sales-sdr-agent
# FASTAIAGENT_TARGET=https://app.fastaiagent.net
