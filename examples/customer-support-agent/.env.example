# ─── Required ────────────────────────────────────────────────
# LLM provider API key (at least one required)
OPENAI_API_KEY=sk-...

# ─── Optional: LLM Model ────────────────────────────────────
# Default: gpt-4o
# LLM_MODEL=gpt-4o
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_MODEL=llama3:8b

# ─── Optional: FastAIAgent Platform ─────────────────────────
# Connect to export traces, pull prompts, publish eval results
# Sign up at https://app.fastaiagent.net
# FASTAIAGENT_API_KEY=fa_k_your_key_here
# FASTAIAGENT_PROJECT=support-bot

# ─── Optional: External Services ────────────────────────────
# Leave blank to use mock implementations
# TICKET_API_URL=https://your-ticket-system.com/api
# CRM_API_URL=https://your-crm.com/api
