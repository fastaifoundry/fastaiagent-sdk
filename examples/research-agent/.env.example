# OpenAI is the default LLM provider used by the example. Required.
OPENAI_API_KEY=sk-...

# Optional model override. Defaults to gpt-4o.
# LLM_MODEL=gpt-4o-mini

# Real web-search providers — uncomment and fill in to swap out the mock
# search backend in tools.py (see SEARCH_BACKEND below).
# TAVILY_API_KEY=tvly-...
# BRAVE_SEARCH_API_KEY=...
# SERPER_API_KEY=...

# Which search backend to use. "mock" is the default and ships ready to run
# offline. Set to "tavily", "brave", or "serper" once you've wired the
# corresponding credentials and updated tools.py.
SEARCH_BACKEND=mock

# Optional FastAIAgent Platform connection (--connect flag).
# FASTAIAGENT_API_KEY=fa_k_...
# FASTAIAGENT_PROJECT=research-agent
# FASTAIAGENT_TARGET=https://app.fastaiagent.net
