# ─── Required ────────────────────────────────────────────────
# OpenAI key (the template uses gpt-4.1-mini by default; pick any
# fastaiagent-supported provider and adjust agent.py to match).
OPENAI_API_KEY=sk-...

# ─── Optional ────────────────────────────────────────────────
# Override the model used by all five scripts (capture / analyze /
# fix / save_test / verify). Defaults to gpt-4.1-mini in agent.py.
# LLM_MODEL=gpt-4.1
