# OpenAI is the default LLM provider. Required.
OPENAI_API_KEY=sk-...

# Optional model override. The main agent defaults to gpt-4o; the
# memory-block side LLMs (SummaryBlock, FactExtractionBlock) default to
# the cheaper gpt-4o-mini since they run on every turn.
# LLM_MODEL=gpt-4o
# MEMORY_LLM_MODEL=gpt-4o-mini

# Where to persist the assistant's memory between sessions. Defaults to
# ``.fastaiagent/memory/`` under this folder. Each block writes its own
# JSON file inside this directory.
# MEMORY_DIR=.fastaiagent/memory

# Identity that StaticBlock pins into every turn's context. Edit to suit
# yourself; the assistant reads this verbatim and addresses you accordingly.
USER_NAME=Friend
USER_ROLE=Software engineer
USER_TZ=UTC

# Optional FastAIAgent Platform connection.
# FASTAIAGENT_API_KEY=fa_k_...
# FASTAIAGENT_PROJECT=personal-assistant
